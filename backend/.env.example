# Peak Practice — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the actual .env file — it contains secrets.
# .env is already listed in .gitignore.

# ── Authentication ────────────────────────────────────────────────────────────
# PEAK_API_KEY: Your custom API key for authenticating with the backend.
#   If not set, a random 32-character hex key is auto-generated on first
#   startup and logged to the console (copy it from there).
#   Example: "my-secret-api-key-12345"
# PEAK_API_KEY=""

# CORS_ORIGIN: Allowed origin for CORS requests from the frontend.
#   Default: "http://localhost:5173"
# CORS_ORIGIN="http://localhost:5173"

# DISABLE_AUTH: Set to "1" to disable API key authentication entirely.
#   Only use this in development — never in production.
#   Default: (unset, auth enabled)
# DISABLE_AUTH=1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE: Max POST requests per minute per client.
#   Default: 60
# RATE_LIMIT_PER_MINUTE="60"

# ── Groq (API Mode) ───────────────────────────────────────────────────────────
# GROQ_API_KEY: API key for Groq cloud inference.
#   Get one at: https://console.groq.com/keys
#   Only used when AI mode is set to "api".
# GROQ_API_KEY=""

# ── OpenRouter (API Mode Fallback) ────────────────────────────────────────────
# OPENROUTER_API_KEY: API key for OpenRouter cloud inference.
#   Get one at: https://openrouter.ai/keys
#   Used as fallback when Groq is unavailable.
# OPENROUTER_API_KEY=""

# ── LM Studio (Local AI — default mode) ───────────────────────────────────────
# LM_STUDIO_BASE_URL: Base URL for the LM Studio local API server.
#   Default: "http://localhost:1234/v1"
LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# LM_STUDIO_API_KEY: API key for LM Studio (usually a placeholder).
#   Default: "lm-studio"
LM_STUDIO_API_KEY="lm-studio"

# LM_STUDIO_TIMEOUT: Timeout in seconds for LM Studio requests.
#   Default: "60"
LM_STUDIO_TIMEOUT="60"
